# ── Azure Resource Config ──────────────────────────────────────────────────────
# Copy this file to deploy.env and fill in your values.
# deploy.env is gitignored — never commit it.

AZURE_RESOURCE_GROUP=
AZURE_APP_SERVICE_PLAN=
AZURE_APP_NAME=

# ── Networking (BC Gov landing zone VNet — pre-existing) ───────────────────────
# The VNet and its RG are managed by the landing zone. Do not change these
# unless your subscription uses different names (check: az network vnet list).
VNET_RESOURCE_GROUP=
VNET_NAME=
PE_SUBNET_NAME=
PE_SUBNET_PREFIX=
WEBAPP_SUBNET_NAME=
WEBAPP_SUBNET_PREFIX=

# ── Azure OpenAI ───────────────────────────────────────────────────────────────
# OPENAI_NAME is used by openai-deploy.ps1 to create the service.
# After running openai-deploy.ps1, fill in AZURE_OPENAI_ENDPOINT and
# AZURE_OPENAI_API_KEY with the values it prints.
OPENAI_NAME=
AZURE_LOCATION=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=

# Fill these in AFTER running openai-deploy.ps1:
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# ── Container Registry ─────────────────────────────────────────────────────────
DOCKER_REGISTRY=
DOCKER_REPOSITORY=

# ── API Security ───────────────────────────────────────────────────────────────
# X-API-Key required on all routes except /health.
API_KEY=your-secret-api-key-here

# ── Runtime ────────────────────────────────────────────────────────────────────
PORT=8000
