FLASK_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_HOST=
DATABASE_PORT=5432

# ── Object Storage API ─────────────────────────────────────────────────────────
# URL of the Object Storage service that issues presigned S3 URLs
OBJECT_STORAGE_URL=

# ── Keycloak service account ───────────────────────────────────────────────────
# Used to authenticate with the Object Storage API
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# ── OpenAI / Azure Extractor Proxy ────────────────────────────────────────────
# Set EXTRACTOR_API_URL to route through the Azure proxy; leave blank for direct OpenAI.
EXTRACTOR_API_URL=
EXTRACTOR_API_KEY=
