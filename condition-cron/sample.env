FLASK_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_HOST=
DATABASE_PORT=5432

# ── S3 Object Storage ──────────────────────────────────────────────────────────
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_HOST=
S3_REGION=
S3_SERVICE=s3

# ── Azure/OpenAI Extractor Proxy ──────────────────────────────────────────────
# Cron uses an OpenAI-compatible endpoint for extraction.
# For the Azure extractor proxy, set EXTRACTOR_API_URL to the proxy base URL
# without /v1; the parser appends /v1 internally.
# Leave EXTRACTOR_API_URL blank only when using direct OPENAI_API_KEY behavior.
EXTRACTOR_API_URL=
EXTRACTOR_API_KEY=

# Optional fallback for direct OpenAI use. Not needed when EXTRACTOR_API_URL and
# EXTRACTOR_API_KEY point at the Azure extractor proxy.
OPENAI_API_KEY=
