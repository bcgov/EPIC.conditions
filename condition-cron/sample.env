FLASK_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_HOST=
DATABASE_PORT=5432

# ── S3 Object Storage ──────────────────────────────────────────────────────────
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_HOST=
S3_REGION=
S3_SERVICE=s3

# ── Azure/OpenAI Extractor Proxy ──────────────────────────────────────────────
# Cron uses an OpenAI-compatible endpoint for extraction.
# For the Azure extractor proxy, set EXTRACTOR_API_URL to the proxy base URL
# without /v1; the parser appends /v1 internally.
# Leave EXTRACTOR_API_URL blank only when using direct OPENAI_API_KEY behavior.
EXTRACTOR_API_URL=
EXTRACTOR_API_KEY=

# Optional fallback for direct OpenAI use. Not needed when EXTRACTOR_API_URL and
# EXTRACTOR_API_KEY point at the Azure extractor proxy.
OPENAI_API_KEY=

# ── Extraction Queue Timing ───────────────────────────────────────────────────
# Keep these values in sync with condition-api.
# Manual update rule:
# 1. If the deployed cron schedule in `cron/crontab` or the config map changes,
#    update EXTRACTION_QUEUE_CRON_INTERVAL_MINUTES here and in condition-api.
# 2. Example: every 30 minutes => 30, every hour => 60.
# 3. EXTRACTION_PROCESSING_ESTIMATE_MINUTES is the estimated time for the
#    single document that a cron run has picked up.
# 4. EXTRACTION_PROCESSING_STALE_AFTER_MINUTES is the retry threshold for a
#    request stuck in `processing`.
EXTRACTION_QUEUE_CRON_INTERVAL_MINUTES=30
EXTRACTION_PROCESSING_ESTIMATE_MINUTES=15
EXTRACTION_PROCESSING_STALE_AFTER_MINUTES=120
